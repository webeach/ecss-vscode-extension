{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "build",
      "sourceMaps": true
    },
    {
      "name": "Launch Extension + Debug Server",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "build",
      "sourceMaps": true,
      "env": {
        "ECSS_DEBUG_SERVER": "1"
      }
    },
    {
      "name": "Attach to LSP Server",
      "type": "node",
      "request": "attach",
      "port": 6009,
      "restart": true,
      "outFiles": ["${workspaceFolder}/dist/server.js"],
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Extension + Server",
      "configurations": [
        "Launch Extension + Debug Server",
        "Attach to LSP Server"
      ]
    }
  ]
}
